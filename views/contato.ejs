<body>
    <div class="container my-5">
        <div class="row align-items-center">
            <div class="col-md-6">
                <div class="card bg-light border-success p-4 shadow">
                    <h3 class="text-success">Mande uma mensagem</h3>
                    <form action="/enviar-contato" method="POST">
                        <label>Nome do cliente:</label>
                        <input type="text" name="nome_usuario" class="form-control" required>

                        <label>Mensagem:</label>
                        <textarea name="mensagem" class="form-control"></textarea>

                        <button type="submit" class="btn btn-primary mt-3">Enviar Dados</button>
                </form>
                </div>
            </div>
            <div class="col-md-6 mt-4 mt-md-0">
                <div class="accordion" id="faqDino">
                </div>
            </div>
        </div>
    </div>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
