<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <title>Mensagens</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="container mt-5">
    <h2>Mensagens dos clientes</h2>
    <a href="/" class="btn btn-secondary mb-3">Voltar</a>

    <div class="row">
        <% dados.forEach(function(item) { %>
            <div class="col-md-4 mb-3">
                <div class="card shadow-sm">
                    <div class="card-body">
                        <h5 class="card-title text-primary"><%= item.nome_usuario %></h5>
                        <p class="card-text">"<%= item.mensagem %>"</p>
                    </div>
                </div>
            </div>
        <% }); %>
    </div>

    <h2>gerenciar mensagens</h2>
    <table class="table table-striped">
        <thead>
            <tr>
                <th>Usuário</th>
                <th>Mensagem</th>
                <th>Ações</th>
            </tr>
        </thead>
        <tbody>
            <% dados.forEach(function(item, i) { %>
                <tr>
                    <td><%= item.nome_usuario %></td>
                    <td><%= item.mensagem %></td>
                    <td>
                        <a href="/apagar?id=<%= i %>" class="btn btn-danger btn-sm" onclick="return confirm('Deseja apagar esta mensagem?')">Apagar</a>
                    </td>
                </tr>
            <% }); %>
        </tbody>
    </table>
    <a href="/" class="btn btn-primary">Voltar</a>
</body>
</html>