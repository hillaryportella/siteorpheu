<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Trabalho Orpheu</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<nav class="navbar navbar-expand-lg navbar-dark bg-dark shadow">
    <div class="container d-flex flex-column align-items-center">
        <a class="navbar-brand fw-bold mb-2 mb-lg-0 mx-auto" href="/index" style="letter-spacing: 2px;">
            DINOSHOP
        </a>
        
        <button class="navbar-toggler mb-2" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
            <span class="navbar-toggler-icon"></span>
        </button>

        <div class="collapse navbar-collapse" id="navbarNav">
            <ul class="navbar-nav mx-auto text-center">
                <li class="nav-item">
                    <a class="nav-link px-3" href="/index">Home</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link px-3" href="/produto">Produtos</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link px-3" href="/fotos">Fotos</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link px-3" href="/detalhes">Detalhes</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link px-3" href="/contato">Contato</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" href="/mensagens">Mensagens</a>
                </li>
            </ul>
        </div>
    </div>
</nav>
<body>
    <div class="container my-5">
        <h2 class="text-center mb-5 text-success fw-bold">Nossos brinquedos</h2>
        <div class="row g-4">
            <div class="col-md-4">
                <div class="card h-100 shadow">
                    <img src="dino1.webp" class="card-img-top" alt="T-Rex">
                    <div class="card-body">
                        <h5 class="card-title text-danger">Tiranossauro Rex</h5>
                        <p class="card-text">O rei dos dinossauros com articulações reais e som de rugido.</p>
                        <button class="btn btn-success w-100">Adicionar ao carrinho</button>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card h-100 shadow">
                    <img src="dino2.webp" class="card-img-top" alt="Triceratops">
                    <div class="card-body">
                        <h5 class="card-title text-success">Tricerátops</h5>
                        <p class="card-text">Resistente, detalhado e perfeito para batalhas.</p>
                        <button class="btn btn-success w-100">Adicionar ao carrinho</button>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card h-100 shadow">
                    <img src="dino3.jpg" class="card-img-top" alt="Velociraptor">
                    <div class="card-body">
                        <h5 class="card-title text-warning text-dark">Pack de Velociraptors</h5>
                        <p class="card-text">Contém 3 figuras.</p>
                        <button class="btn btn-success w-100">Adicionar ao carrinho</button>
                    </div>
                </div>
            </div>
        </div>
    </div>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
